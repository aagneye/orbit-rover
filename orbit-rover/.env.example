# =============================================================================
# Orbit Rover — environment variables
# Copy to .env for local dev, or paste into Render → Environment for production
# Full guide: docs/LIVE_SETUP.md
# =============================================================================

# --- GitLab API (bot: pipeline logs, MR comments) ---
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=orbit-rover-secret

# --- GitLab OAuth (dashboard login — NO Google) ---
AUTH_ENABLED=false
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/gitlab/callback
GITLAB_OAUTH_SCOPES=read_user api read_api
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_SECURE=false

# --- Orbit Knowledge Graph ---
ORBIT_ENABLED=true
ORBIT_USE_MOCK=true

# --- LLM: mock | openai | anthropic | ollama ---
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- App URLs (LOCAL) ---
DEBUG=false
POST_MR_COMMENT=true
CORS_ORIGINS=http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# --- Database ---
# Local dev: leave empty or use SQLite below
# Render (no Neon yet): sqlite+aiosqlite:////tmp/orbit_rover.db
# Production: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./data/orbit_rover.db

# =============================================================================
# RENDER PRODUCTION — paste these in Render → orbit-rover-api → Environment
# Replace orbit-rover-api / orbit-rover.vercel.app with your real hostnames
# =============================================================================
#
# GITLAB_TOKEN=glpat-xxxxxxxxxxxx
# GITLAB_WEBHOOK_SECRET=your-long-random-secret
# GITLAB_OAUTH_CLIENT_ID=your-gitlab-app-id
# GITLAB_OAUTH_CLIENT_SECRET=your-gitlab-app-secret
# GITLAB_OAUTH_REDIRECT_URI=https://orbit-rover-api.onrender.com/auth/gitlab/callback
#
# PUBLIC_API_URL=https://orbit-rover-api.onrender.com
# DASHBOARD_BASE_URL=https://orbit-rover.vercel.app
# CORS_ORIGINS=https://orbit-rover.vercel.app
#
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#
# AUTH_ENABLED=true
# SESSION_SECRET=generate-64-char-random-string
# SESSION_COOKIE_SECURE=true
# LLM_PROVIDER=mock
# ORBIT_USE_MOCK=true
# POST_MR_COMMENT=true
