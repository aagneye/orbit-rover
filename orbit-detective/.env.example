# GitLab API (bot — reads logs, posts MR comments)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=orbit-detective-secret

# GitLab OAuth (dashboard login — NO Google)
AUTH_ENABLED=false
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/gitlab/callback
GITLAB_OAUTH_SCOPES=read_user api read_api
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_SECURE=false

# Orbit Knowledge Graph
ORBIT_ENABLED=true
ORBIT_USE_MOCK=true

# LLM Provider: mock | openai | anthropic | ollama
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# App URLs
DEBUG=false
POST_MR_COMMENT=true
CORS_ORIGINS=http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# Database — local SQLite; production use Neon (see docs/LIVE_SETUP.md)
# DATABASE_URL=sqlite+aiosqlite:///./data/orbit_detective.db
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./data/orbit_detective.db
