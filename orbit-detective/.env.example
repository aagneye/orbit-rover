# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=orbit-detective-secret

# Orbit Knowledge Graph
ORBIT_ENABLED=true
ORBIT_USE_MOCK=true

# LLM Provider: mock | openai | anthropic | ollama
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# App
DEBUG=false
POST_MR_COMMENT=true
CORS_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite+aiosqlite:///./data/orbit_detective.db
